# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# APP_URL=

# EDITOR_PASSWORD: Optional password to gate editor actions and blog post generation. Defaults to "meridian" if not specified.
# EDITOR_PASSWORD=

# GITHUB_TOKEN: Optional GitHub Personal Access Token to use GitHub Models (e.g. gpt-4o, gpt-4o-mini, llama-3.1) as fallback when Gemini is rate-limited or unavailable.
# GITHUB_TOKEN=

# SMTP Email Configuration: Used by the Daily Research Journal Predictor to send daily options to your inbox.
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# USER_EMAIL=
